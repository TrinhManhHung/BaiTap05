<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/tvBookingMovieTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên phim"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#333333"/>

    <TextView
        android:id="@+id/tvBookingShowtimeInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rạp - Giờ chiếu"
        android:textSize="14sp"
        android:textColor="#E91E63"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MÀN HÌNH"
        android:gravity="center"
        android:background="#DDDDDD"
        android:padding="4dp"
        android:layout_marginBottom="24dp"/>

    <GridView
        android:id="@+id/gvSeats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="5"
        android:verticalSpacing="8dp"
        android:horizontalSpacing="8dp"
        android:gravity="center"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center">
        <View android:layout_width="20dp" android:layout_height="20dp" android:background="@android:color/holo_red_light"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Trống  " />
        <View android:layout_width="20dp" android:layout_height="20dp" android:background="@android:color/holo_green_dark"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Đang chọn  " />
        <View android:layout_width="20dp" android:layout_height="20dp" android:background="@android:color/darker_gray"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Đã đặt" />
    </LinearLayout>

    <Button
        android:id="@+id/btnConfirmBooking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="XÁC NHẬN ĐẶT VÉ"
        android:backgroundTint="#E91E63"
        android:textColor="#FFFFFF"
        android:layout_marginTop="16dp"/>

</LinearLayout>
